STIQUE,&#xD;&#xA;    POIDS_BRUT_ART_ACHETE,&#xD;&#xA;    POIDS_NET_ART_ACHETE,&#xD;&#xA;    POIDS_BRUT_ART_FABRIQUE,&#xD;&#xA;    POIDS_NET_ART_FABRIQUE,&#xD;&#xA;    PRIX_UNITAIRE_BASE,&#xD;&#xA;    CODE_VENDEUR,&#xD;&#xA;    COUT_SEMIN_DEV_SOC,&#xD;&#xA;    GRATUIT,&#xD;&#xA;    NOUVEAU_CODE_MAGASIN,&#xD;&#xA;    TRANSFERT_MAGASIN,&#xD;&#xA;    SALES_RATE_ENTRY_NO,&#xD;&#xA;    POIDS_BRUT_ART_PROFILES,&#xD;&#xA;    POIDS_NET_ART_PROFILES,&#xD;&#xA;    SHIP_UNIT_OF_MEASURE,&#xD;&#xA;    EDI_ORDER_NO,&#xD;&#xA;    EDI_ORDER_LINE_NO,&#xD;&#xA;    EDI_NO,&#xD;&#xA;    NO_CONTRAT,&#xD;&#xA;    NO_EXTRACTION,&#xD;&#xA;    ERREUR_IMPORT_EDI,&#xD;&#xA;    CAMPAIGN_NO,&#xD;&#xA;    COUNTERMARK_CODE,&#xD;&#xA;    DEFERRAL_CODE,&#xD;&#xA;    RETURNS_DEFERRAL_START_DATE,&#xD;&#xA;    PROMOTION_NO,&#xD;&#xA;    INITIAL_QTY_BEFORE_PROMO,&#xD;&#xA;    CHARGE_ITEM_GROUP_CODE,&#xD;&#xA;    REQ_DELIVERY_DATE_EXEMPTION&#xD;&#xA;FROM CTE&#xD;&#xA;WHERE RN = 1;&#xD;&#xA;&quot;"/>
