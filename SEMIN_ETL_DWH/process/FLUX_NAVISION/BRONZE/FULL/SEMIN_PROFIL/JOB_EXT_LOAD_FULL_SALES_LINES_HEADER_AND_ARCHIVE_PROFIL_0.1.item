  <node componentName="tMSSqlInput" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="240" posY="1000">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBInput_2" show="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_1"/>
    <elementParameter field="TEXT" name="HOST" value="&quot;ULYSSE\\NAVISION&quot;" show="false"/>
    <elementParameter field="CLOSED_LIST" name="DRIVER" value="MSSQL_PROP" show="false"/>
    <elementParameter field="TEXT" name="TYPE" value="MSSQL" show="false"/>
    <elementParameter field="TEXT" name="PORT" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="DB_SCHEMA" value="&quot;dbo&quot;" show="false"/>
    <elementParameter field="TEXT" name="DBNAME" value="&quot;SEMIN&quot;" show="false"/>
    <elementParameter field="TEXT" name="USER" value="&quot;SQLTalend&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:Uwb5eHAIp8MZVjAxctsGLdO8pHsqdSHKaB7jFbUWKr1ByaHqAA4jqABa" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value=" ((String)globalMap.get(&quot;SQLServer_Table2&quot;))"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;WITH CTE AS (&#xD;&#xA;    SELECT&#xD;&#xA;        CONVERT(VARCHAR(16), [timestamp], 2) AS TIMESTAMP,&#xD;&#xA;        TRY_CAST([Document Type] AS INT) AS DOCUMENT_TYPE,&#xD;&#xA;        [Document No_] AS DOCUMENT_NO,&#xD;&#xA;        TRY_CAST([Doc_ No_ Occurrence] AS INT) AS DOC_NO_OCCURRENCE,&#xD;&#xA;        TRY_CAST([Version No_] AS INT) AS VERSION_NO,&#xD;&#xA;        TRY_CAST([Line No_] AS INT) AS LINE_NO,&#xD;&#xA;        [Sell-to Customer No_] AS SELL_TO_CUSTOMER_NO,&#xD;&#xA;        TRY_CAST([Type] AS INT) AS TYPE,&#xD;&#xA;        [No_] AS NO,&#xD;&#xA;        [Location Code] AS LOCATION_CODE,&#xD;&#xA;        [Posting Group] AS POSTING_GROUP,&#xD;&#xA;        [Quantity Disc_ Code] AS QUANTITY_DISC_CODE,&#xD;&#xA;        CONVERT(VARCHAR(10), [Shipment Date], 23) AS SHIPMENT_DATE,&#xD;&#xA;        [Description] AS DESCRIPTION,&#xD;&#xA;        [Description 2] AS DESCRIPTION_2,&#xD;&#xA;        [Unit of Measure] AS UNIT_OF_MEASURE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Quantity] AS DECIMAL(38,20))), ',', '.') AS QUANTITY,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Outstanding Quantity] AS DECIMAL(38,20))), ',', '.') AS OUTSTANDING_QUANTITY,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Qty_ to Invoice] AS DECIMAL(38,20))), ',', '.') AS QTY_TO_INVOICE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Qty_ to Ship] AS DECIMAL(38,20))), ',', '.') AS QTY_TO_SHIP,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Unit Price] AS DECIMAL(38,20))), ',', '.') AS UNIT_PRICE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Unit Cost (LCY)] AS DECIMAL(38,20))), ',', '.') AS UNIT_COST_LCY,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([VAT _] AS DECIMAL(38,20))), ',', '.') AS VAT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Quantity Disc_ _] AS DECIMAL(38,20))), ',', '.') AS QUANTITY_DISC,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Line Discount _] AS DECIMAL(38,20))), ',', '.') AS LINE_DISCOUNT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Line Discount Amount] AS DECIMAL(38,20))), ',', '.') AS LINE_DISCOUNT_AMOUNT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Amount] AS DECIMAL(38,20))), ',', '.') AS AMOUNT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Amount Including VAT] AS DECIMAL(38,20))), ',', '.') AS AMOUNT_INCLUDING_VAT,&#xD;&#xA;        TRY_CAST([Allow Invoice Disc_] AS INT) AS ALLOW_INVOICE_DISC,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Gross Weight] AS DECIMAL(38,20))), ',', '.') AS GROSS_WEIGHT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Net Weight] AS DECIMAL(38,20))), ',', '.') AS NET_WEIGHT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Units per Parcel] AS DECIMAL(38,20))), ',', '.') AS UNITS_PER_PARCEL,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Unit Volume] AS DECIMAL(38,20))), ',', '.') AS UNIT_VOLUME,&#xD;&#xA;        TRY_CAST([Appl_-to Item Entry] AS INT) AS APPL_TO_ITEM_ENTRY,&#xD;&#xA;        [Shortcut Dimension 1 Code] AS SHORTCUT_DIMENSION_1_CODE,&#xD;&#xA;        [Shortcut Dimension 2 Code] AS SHORTCUT_DIMENSION_2_CODE,&#xD;&#xA;        [Price Group Code] AS PRICE_GROUP_CODE,&#xD;&#xA;        TRY_CAST([Allow Quantity Disc_] AS INT) AS ALLOW_QUANTITY_DISC,&#xD;&#xA;        [Job No_] AS JOB_NO,&#xD;&#xA;        [Work Type Code] AS WORK_TYPE_CODE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Cust__Item Disc_ _] AS DECIMAL(38,20))), ',', '.') AS CUST_ITEM_DISC,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Outstanding Amount] AS DECIMAL(38,20))), ',', '.') AS OUTSTANDING_AMOUNT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Qty_ Shipped Not Invoiced] AS DECIMAL(38,20))), ',', '.') AS QTY_SHIPPED_NOT_INVOICED,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Shipped Not Invoiced] AS DECIMAL(38,20))), ',', '.') AS SHIPPED_NOT_INVOICED,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Quantity Shipped] AS DECIMAL(38,20))), ',', '.') AS QUANTITY_SHIPPED,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Quantity Invoiced] AS DECIMAL(38,20))), ',', '.') AS QUANTITY_INVOICED,&#xD;&#xA;        [Shipment No_] AS SHIPMENT_NO,&#xD;&#xA;        TRY_CAST([Shipment Line No_] AS INT) AS SHIPMENT_LINE_NO,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Profit _] AS DECIMAL(38,20))), ',', '.') AS PROFIT,&#xD;&#xA;        [Bill-to Customer No_] AS BILL_TO_CUSTOMER_NO,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Inv_ Discount Amount] AS DECIMAL(38,20))), ',', '.') AS INV_DISCOUNT_AMOUNT,&#xD;&#xA;        [Purchase Order No_] AS PURCHASE_ORDER_NO,&#xD;&#xA;        TRY_CAST([Purch_ Order Line No_] AS INT) AS PURCH_ORDER_LINE_NO,&#xD;&#xA;        TRY_CAST([Drop Shipment] AS INT) AS DROP_SHIPMENT,&#xD;&#xA;        [Gen_ Bus_ Posting Group] AS GEN_BUS_POSTING_GROUP,&#xD;&#xA;        [Gen_ Prod_ Posting Group] AS GEN_PROD_POSTING_GROUP,&#xD;&#xA;        TRY_CAST([VAT Calculation Type] AS INT) AS VAT_CALCULATION_TYPE,&#xD;&#xA;        [Transaction Type] AS TRANSACTION_TYPE,&#xD;&#xA;        [Transport Method] AS TRANSPORT_METHOD,&#xD;&#xA;        TRY_CAST([Attached to Line No_] AS INT) AS ATTACHED_TO_LINE_NO,&#xD;&#xA;        [Exit Point] AS EXIT_POINT,&#xD;&#xA;        [Area] AS AREA,&#xD;&#xA;        [Transaction Specification] AS TRANSACTION_SPECIFICATION,&#xD;&#xA;        [Tax Area Code] AS TAX_AREA_CODE,&#xD;&#xA;        TRY_CAST([Tax Liable] AS INT) AS TAX_LIABLE,&#xD;&#xA;        [Tax Group Code] AS TAX_GROUP_CODE,&#xD;&#xA;        [VAT Bus_ Posting Group] AS VAT_BUS_POSTING_GROUP,&#xD;&#xA;        [VAT Prod_ Posting Group] AS VAT_PROD_POSTING_GROUP,&#xD;&#xA;        [Currency Code] AS CURRENCY_CODE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Outstanding Amount (LCY)] AS DECIMAL(38,20))), ',', '.') AS OUTSTANDING_AMOUNT_LCY,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Shipped Not Invoiced (LCY)] AS DECIMAL(38,20))), ',', '.') AS SHIPPED_NOT_INVOICED_LCY,&#xD;&#xA;        TRY_CAST([Reserve] AS INT) AS RESERVE,&#xD;&#xA;        [Blanket Order No_] AS BLANKET_ORDER_NO,&#xD;&#xA;        TRY_CAST([Blanket Order Line No_] AS INT) AS BLANKET_ORDER_LINE_NO,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([VAT Base Amount] AS DECIMAL(38,20))), ',', '.') AS VAT_BASE_AMOUNT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Unit Cost] AS DECIMAL(38,20))), ',', '.') AS UNIT_COST,&#xD;&#xA;        TRY_CAST([System-Created Entry] AS INT) AS SYSTEM_CREATED_ENTRY,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Line Amount] AS DECIMAL(38,20))), ',', '.') AS LINE_AMOUNT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([VAT Difference] AS DECIMAL(38,20))), ',', '.') AS VAT_DIFFERENCE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Inv_ Disc_ Amount to Invoice] AS DECIMAL(38,20))), ',', '.') AS INV_DISC_AMOUNT_TO_INVOICE,&#xD;&#xA;        [VAT Identifier] AS VAT_IDENTIFIER,&#xD;&#xA;        TRY_CAST([IC Partner Ref_ Type] AS INT) AS IC_PARTNER_REF_TYPE,&#xD;&#xA;        [IC Partner Reference] AS IC_PARTNER_REFERENCE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepayment _] AS DECIMAL(38,20))), ',', '.') AS PREPAYMENT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepmt_ Line Amount] AS DECIMAL(38,20))), ',', '.') AS PREPMT_LINE_AMOUNT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepmt_ Amt_ Inv_] AS DECIMAL(38,20))), ',', '.') AS PREPMT_AMT_INV,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepmt_ Amt_ Incl_ VAT] AS DECIMAL(38,20))), ',', '.') AS PREPMT_AMT_INCL_VAT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepayment Amount] AS DECIMAL(38,20))), ',', '.') AS PREPAYMENT_AMOUNT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepmt_ VAT Base Amt_] AS DECIMAL(38,20))), ',', '.') AS PREPMT_VAT_BASE_AMT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepayment VAT _] AS DECIMAL(38,20))), ',', '.') AS PREPAYMENT_VAT,&#xD;&#xA;        TRY_CAST([Prepmt_ VAT Calc_ Type] AS INT) AS PREPMT_VAT_CALC_TYPE,&#xD;&#xA;        [Prepayment VAT Identifier] AS PREPAYMENT_VAT_IDENTIFIER,&#xD;&#xA;        [Prepayment Tax Area Code] AS PREPAYMENT_TAX_AREA_CODE,&#xD;&#xA;        TRY_CAST([Prepayment Tax Liable] AS INT) AS PREPAYMENT_TAX_LIABLE,&#xD;&#xA;        [Prepayment Tax Group Code] AS PREPAYMENT_TAX_GROUP_CODE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepmt Amt to Deduct] AS DECIMAL(38,20))), ',', '.') AS PREPMT_AMT_TO_DEDUCT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepmt Amt Deducted] AS DECIMAL(38,20))), ',', '.') AS PREPMT_AMT_DEDUCTED,&#xD;&#xA;        TRY_CAST([Prepayment Line] AS INT) AS PREPAYMENT_LINE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prepmt_ Amount Inv_ Incl_ VAT] AS DECIMAL(38,20))), ',', '.') AS PREPMT_AMOUNT_INV_INCL_VAT,&#xD;&#xA;        [IC Partner Code] AS IC_PARTNER_CODE,&#xD;&#xA;        TRY_CAST([Dimension Set ID] AS INT) AS DIMENSION_SET_ID,&#xD;&#xA;        [Variant Code] AS VARIANT_CODE,&#xD;&#xA;        [Bin Code] AS BIN_CODE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Qty_ per Unit of Measure] AS DECIMAL(38,20))), ',', '.') AS QTY_PER_UNIT_OF_MEASURE,&#xD;&#xA;        TRY_CAST([Planned] AS INT) AS PLANNED,&#xD;&#xA;        [Unit of Measure Code] AS UNIT_OF_MEASURE_CODE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Quantity (Base)] AS DECIMAL(38,20))), ',', '.') AS QUANTITY_BASE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Outstanding Qty_ (Base)] AS DECIMAL(38,20))), ',', '.') AS OUTSTANDING_QTY_BASE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Qty_ to Invoice (Base)] AS DECIMAL(38,20))), ',', '.') AS QTY_TO_INVOICE_BASE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Qty_ to Ship (Base)] AS DECIMAL(38,20))), ',', '.') AS QTY_TO_SHIP_BASE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Qty_ Shipped Not Invd_ (Base)] AS DECIMAL(38,20))), ',', '.') AS QTY_SHIPPED_NOT_INVD_BASE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Qty_ Shipped (Base)] AS DECIMAL(38,20))), ',', '.') AS QTY_SHIPPED_BASE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Qty_ Invoiced (Base)] AS DECIMAL(38,20))), ',', '.') AS QTY_INVOICED_BASE,&#xD;&#xA;        CONVERT(VARCHAR(10), [FA Posting Date], 23) AS FA_POSTING_DATE,&#xD;&#xA;        [Depreciation Book Code] AS DEPRECIATION_BOOK_CODE,&#xD;&#xA;        TRY_CAST([Depr_ until FA Posting Date] AS INT) AS DEPR_UNTIL_FA_POSTING_DATE,&#xD;&#xA;        [Duplicate in Depreciation Book] AS DUPLICATE_IN_DEPRECIATION_BOOK,&#xD;&#xA;        TRY_CAST([Use Duplication List] AS INT) AS USE_DUPLICATION_LIST,&#xD;&#xA;        [Responsibility Center] AS RESPONSIBILITY_CENTER,&#xD;&#xA;        TRY_CAST([Out-of-Stock Substitution] AS INT) AS OUT_OF_STOCK_SUBSTITUTION,&#xD;&#xA;        [Originally Ordered No_] AS ORIGINALLY_ORDERED_NO,&#xD;&#xA;        [Originally Ordered Var_ Code] AS ORIGINALLY_ORDERED_VAR_CODE,&#xD;&#xA;        [Cross-Reference No_] AS CROSS_REFERENCE_NO,&#xD;&#xA;        [Unit of Measure (Cross Ref_)] AS UNIT_OF_MEASURE_CROSS_REF,&#xD;&#xA;        TRY_CAST([Cross-Reference Type] AS INT) AS CROSS_REFERENCE_TYPE,&#xD;&#xA;        [Cross-Reference Type No_] AS CROSS_REFERENCE_TYPE_NO,&#xD;&#xA;        [Item Category Code] AS ITEM_CATEGORY_CODE,&#xD;&#xA;        TRY_CAST([Nonstock] AS INT) AS NONSTOCK,&#xD;&#xA;        [Purchasing Code] AS PURCHASING_CODE,&#xD;&#xA;        [Product Group Code] AS PRODUCT_GROUP_CODE,&#xD;&#xA;        TRY_CAST([Special Order] AS INT) AS SPECIAL_ORDER,&#xD;&#xA;        [Special Order Purchase No_] AS SPECIAL_ORDER_PURCHASE_NO,&#xD;&#xA;        TRY_CAST([Special Order Purch_ Line No_] AS INT) AS SPECIAL_ORDER_PURCH_LINE_NO,&#xD;&#xA;        TRY_CAST([Completely Shipped] AS INT) AS COMPLETELY_SHIPPED,&#xD;&#xA;        CONVERT(VARCHAR(10), [Requested Delivery Date], 23) AS REQUESTED_DELIVERY_DATE,&#xD;&#xA;        CONVERT(VARCHAR(10), [Promised Delivery Date], 23) AS PROMISED_DELIVERY_DATE,&#xD;&#xA;        [Shipping Time] AS SHIPPING_TIME,&#xD;&#xA;        [Outbound Whse_ Handling Time] AS OUTBOUND_WHSE_HANDLING_TIME,&#xD;&#xA;        CONVERT(VARCHAR(10), [Planned Delivery Date], 23) AS PLANNED_DELIVERY_DATE,&#xD;&#xA;        CONVERT(VARCHAR(10), [Planned Shipment Date], 23) AS PLANNED_SHIPMENT_DATE,&#xD;&#xA;        [Shipping Agent Code] AS SHIPPING_AGENT_CODE,&#xD;&#xA;        [Shipping Agent Service Code] AS SHIPPING_AGENT_SERVICE_CODE,&#xD;&#xA;        TRY_CAST([Allow Item Charge Assignment] AS INT) AS ALLOW_ITEM_CHARGE_ASSIGNMENT,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Return Qty_ to Receive] AS DECIMAL(38,20))), ',', '.') AS RETURN_QTY_TO_RECEIVE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Return Qty_ to Receive (Base)] AS DECIMAL(38,20))), ',', '.') AS RETURN_QTY_TO_RECEIVE_BASE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Return Qty_ Rcd_ Not Invd_] AS DECIMAL(38,20))), ',', '.') AS RETURN_QTY_RCD_NOT_INVD,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Ret_ Qty_ Rcd_ Not Invd_(Base)] AS DECIMAL(38,20))), ',', '.') AS RET_QTY_RCD_NOT_INVD_BASE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Return Amt_ Rcd_ Not Invd_] AS DECIMAL(38,20))), ',', '.') AS RETURN_AMT_RCD_NOT_INVD,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Ret_ Amt_ Rcd_ Not Invd_ (LCY)] AS DECIMAL(38,20))), ',', '.') AS RET_AMT_RCD_NOT_INVD_LCY,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Return Qty_ Received] AS DECIMAL(38,20))), ',', '.') AS RETURN_QTY_RECEIVED,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Return Qty_ Received (Base)] AS DECIMAL(38,20))), ',', '.') AS RETURN_QTY_RECEIVED_BASE,&#xD;&#xA;        TRY_CAST([Appl_-from Item Entry] AS INT) AS APPL_FROM_ITEM_ENTRY,&#xD;&#xA;        [Service Contract No_] AS SERVICE_CONTRACT_NO,&#xD;&#xA;        [Service Order No_] AS SERVICE_ORDER_NO,&#xD;&#xA;        [Service Item No_] AS SERVICE_ITEM_NO,&#xD;&#xA;        TRY_CAST([Appl_-to Service Entry] AS INT) AS APPL_TO_SERVICE_ENTRY,&#xD;&#xA;        TRY_CAST([Service Item Line No_] AS INT) AS SERVICE_ITEM_LINE_NO,&#xD;&#xA;        [Serv_ Price Adjmt_ Gr_ Code] AS SERV_PRICE_ADJMT_GR_CODE,&#xD;&#xA;        [BOM Item No_] AS BOM_ITEM_NO,&#xD;&#xA;        [Return Receipt No_] AS RETURN_RECEIPT_NO,&#xD;&#xA;        TRY_CAST([Return Receipt Line No_] AS INT) AS RETURN_RECEIPT_LINE_NO,&#xD;&#xA;        [Return Reason Code] AS RETURN_REASON_CODE,&#xD;&#xA;        TRY_CAST([Allow Line Disc_] AS INT) AS ALLOW_LINE_DISC,&#xD;&#xA;        [Customer Disc_ Group] AS CUSTOMER_DISC_GROUP,&#xD;&#xA;        [Unité condmnt_ multiple] AS UNITE_CONDMNT_MULTIPLE,&#xD;&#xA;        TRY_CAST([Intégrer ds calc_ poids Franco] AS INT) AS INTEGRER_DS_CALC_POIDS_FRANCO,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Poids mini franco] AS DECIMAL(38,20))), ',', '.') AS POIDS_MINI_FRANCO,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Remise 1] AS DECIMAL(38,20))), ',', '.') AS REMISE_1,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Remise 2] AS DECIMAL(38,20))), ',', '.') AS REMISE_2,&#xD;&#xA;        TRY_CAST([Autoriser MAJ Franco] AS INT) AS AUTORISER_MAJ_FRANCO,&#xD;&#xA;        [Code transporteur] AS CODE_TRANSPORTEUR,&#xD;&#xA;        TRY_CAST([Validation service logistique] AS INT) AS VALIDATION_SERVICE_LOGISTIQUE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Poids brut art_ acheté] AS DECIMAL(38,20))), ',', '.') AS POIDS_BRUT_ART_ACHETE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Poids net art_ acheté] AS DECIMAL(38,20))), ',', '.') AS POIDS_NET_ART_ACHETE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Poids brut art_ fabriqué] AS DECIMAL(38,20))), ',', '.') AS POIDS_BRUT_ART_FABRIQUE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Poids net art_ fabriqué] AS DECIMAL(38,20))), ',', '.') AS POIDS_NET_ART_FABRIQUE,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Prix unitaire (base)] AS DECIMAL(38,20))), ',', '.') AS PRIX_UNITAIRE_BASE,&#xD;&#xA;        [Code vendeur] AS CODE_VENDEUR,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Coût semin (dev soc)] AS DECIMAL(38,20))), ',', '.') AS COUT_SEMIN_DEV_SOC,&#xD;&#xA;        TRY_CAST([Gratuit] AS INT) AS GRATUIT,&#xD;&#xA;        [Nouveau code magasin] AS NOUVEAU_CODE_MAGASIN,&#xD;&#xA;        TRY_CAST([Transfert magasin] AS INT) AS TRANSFERT_MAGASIN,&#xD;&#xA;        TRY_CAST([Sales Rate Entry No_] AS INT) AS SALES_RATE_ENTRY_NO,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Poids brut art_ profiles] AS DECIMAL(38,20))), ',', '.') AS POIDS_BRUT_ART_PROFILES,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Poids net art_ profiles] AS DECIMAL(38,20))), ',', '.') AS POIDS_NET_ART_PROFILES,&#xD;&#xA;        [Ship_ Unit of Measure] AS SHIP_UNIT_OF_MEASURE,&#xD;&#xA;        [Edi Order No_] AS EDI_ORDER_NO,&#xD;&#xA;        [Edi Order Line No_] AS EDI_ORDER_LINE_NO,&#xD;&#xA;        [Edi No_] AS EDI_NO,&#xD;&#xA;        [No_ contrat] AS NO_CONTRAT,&#xD;&#xA;        [No_ extraction] AS NO_EXTRACTION,&#xD;&#xA;        TRY_CAST([Erreur Import EDI] AS INT) AS ERREUR_IMPORT_EDI,&#xD;&#xA;        [Campaign No_] AS CAMPAIGN_NO,&#xD;&#xA;        [Countermark Code] AS COUNTERMARK_CODE,&#xD;&#xA;        [Deferral Code] AS DEFERRAL_CODE,&#xD;&#xA;        CONVERT(VARCHAR(10), [Returns Deferral Start Date], 23) AS RETURNS_DEFERRAL_START_DATE,&#xD;&#xA;        [Promotion No_] AS PROMOTION_NO,&#xD;&#xA;        REPLACE(CONVERT(VARCHAR(50), TRY_CAST([Initial Qty Before Promo] AS DECIMAL(38,20))), ',', '.') AS INITIAL_QTY_BEFORE_PROMO,&#xD;&#xA;        [Charge Item Group Code] AS CHARGE_ITEM_GROUP_CODE,&#xD;&#xA;        CONVERT(VARCHAR(10), [Req_ Delivery Date Exemption], 23) AS REQ_DELIVERY_DATE_EXEMPTION,&#xD;&#xA;&#xD;&#xA;        ROW_NUMBER() OVER (&#xD;&#xA;            PARTITION BY [Document No_], TRY_CAST([Line No_] AS INT)&#xD;&#xA;            ORDER BY&#xD;&#xA;                TRY_CAST([Doc_ No_ Occurrence] AS INT) DESC,&#xD;&#xA;                TRY_CAST([Version No_] AS INT) DESC&#xD;&#xA;        ) AS RN&#xD;&#xA;&#xD;&#xA;    FROM &quot;+ ((String)globalMap.get(&quot;SQLServer_Table2&quot;))+&quot;&#xD;&#xA;    WHERE [Document Type] = 1&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;SELECT&#xD;&#xA;    TIMESTAMP,&#xD;&#xA;    DOCUMENT_TYPE,&#xD;&#xA;    DOCUMENT_NO,&#xD;&#xA;    DOC_NO_OCCURRENCE,&#xD;&#xA;    VERSION_NO,&#xD;&#xA;    LINE_NO,&#xD;&#xA;    SELL_TO_CUSTOMER_NO,&#xD;&#xA;    TYPE,&#xD;&#xA;    NO,&#xD;&#xA;    LOCATION_CODE,&#xD;&#xA;    POSTING_GROUP,&#xD;&#xA;    QUANTITY_DISC_CODE,&#xD;&#xA;    SHIPMENT_DATE,&#xD;&#xA;    DESCRIPTION,&#xD;&#xA;    DESCRIPTION_2,&#xD;&#xA;    UNIT_OF_MEASURE,&#xD;&#xA;    QUANTITY,&#xD;&#xA;    OUTSTANDING_QUANTITY,&#xD;&#xA;    QTY_TO_INVOICE,&#xD;&#xA;    QTY_TO_SHIP,&#xD;&#xA;    UNIT_PRICE,&#xD;&#xA;    UNIT_COST_LCY,&#xD;&#xA;    VAT,&#xD;&#xA;    QUANTITY_DISC,&#xD;&#xA;    LINE_DISCOUNT,&#xD;&#xA;    LINE_DISCOUNT_AMOUNT,&#xD;&#xA;    AMOUNT,&#xD;&#xA;    AMOUNT_INCLUDING_VAT,&#xD;&#xA;    ALLOW_INVOICE_DISC,&#xD;&#xA;    GROSS_WEIGHT,&#xD;&#xA;    NET_WEIGHT,&#xD;&#xA;    UNITS_PER_PARCEL,&#xD;&#xA;    UNIT_VOLUME,&#xD;&#xA;    APPL_TO_ITEM_ENTRY,&#xD;&#xA;    SHORTCUT_DIMENSION_1_CODE,&#xD;&#xA;    SHORTCUT_DIMENSION_2_CODE,&#xD;&#xA;    PRICE_GROUP_CODE,&#xD;&#xA;    ALLOW_QUANTITY_DISC,&#xD;&#xA;    JOB_NO,&#xD;&#xA;    WORK_TYPE_CODE,&#xD;&#xA;    CUST_ITEM_DISC,&#xD;&#xA;    OUTSTANDING_AMOUNT,&#xD;&#xA;    QTY_SHIPPED_NOT_INVOICED,&#xD;&#xA;    SHIPPED_NOT_INVOICED,&#xD;&#xA;    QUANTITY_SHIPPED,&#xD;&#xA;    QUANTITY_INVOICED,&#xD;&#xA;    SHIPMENT_NO,&#xD;&#xA;    SHIPMENT_LINE_NO,&#xD;&#xA;    PROFIT,&#xD;&#xA;    BILL_TO_CUSTOMER_NO,&#xD;&#xA;    INV_DISCOUNT_AMOUNT,&#xD;&#xA;    PURCHASE_ORDER_NO,&#xD;&#xA;    PURCH_ORDER_LINE_NO,&#xD;&#xA;    DROP_SHIPMENT,&#xD;&#xA;    GEN_BUS_POSTING_GROUP,&#xD;&#xA;    GEN_PROD_POSTING_GROUP,&#xD;&#xA;    VAT_CALCULATION_TYPE,&#xD;&#xA;    TRANSACTION_TYPE,&#xD;&#xA;    TRANSPORT_METHOD,&#xD;&#xA;    ATTACHED_TO_LINE_NO,&#xD;&#xA;    EXIT_POINT,&#xD;&#xA;    AREA,&#xD;&#xA;    TRANSACTION_SPECIFICATION,&#xD;&#xA;    TAX_AREA_CODE,&#xD;&#xA;    TAX_LIABLE,&#xD;&#xA;    TAX_GROUP_CODE,&#xD;&#xA;    VAT_BUS_POSTING_GROUP,&#xD;&#xA;    VAT_PROD_POSTING_GROUP,&#xD;&#xA;    CURRENCY_CODE,&#xD;&#xA;    OUTSTANDING_AMOUNT_LCY,&#xD;&#xA;    SHIPPED_NOT_INVOICED_LCY,&#xD;&#xA;    RESERVE,&#xD;&#xA;    BLANKET_ORDER_NO,&#xD;&#xA;    BLANKET_ORDER_LINE_NO,&#xD;&#xA;    VAT_BASE_AMOUNT,&#xD;&#xA;    UNIT_COST,&#xD;&#xA;    SYSTEM_CREATED_ENTRY,&#xD;&#xA;    LINE_AMOUNT,&#xD;&#xA;    VAT_DIFFERENCE,&#xD;&#xA;    INV_DISC_AMOUNT_TO_INVOICE,&#xD;&#xA;    VAT_IDENTIFIER,&#xD;&#xA;    IC_PARTNER_REF_TYPE,&#xD;&#xA;    IC_PARTNER_REFERENCE,&#xD;&#xA;    PREPAYMENT,&#xD;&#xA;    PREPMT_LINE_AMOUNT,&#xD;&#xA;    PREPMT_AMT_INV,&#xD;&#xA;    PREPMT_AMT_INCL_VAT,&#xD;&#xA;    PREPAYMENT_AMOUNT,&#xD;&#xA;    PREPMT_VAT_BASE_AMT,&#xD;&#xA;    PREPAYMENT_VAT,&#xD;&#xA;    PREPMT_VAT_CALC_TYPE,&#xD;&#xA;    PREPAYMENT_VAT_IDENTIFIER,&#xD;&#xA;    PREPAYMENT_TAX_AREA_CODE,&#xD;&#xA;    PREPAYMENT_TAX_LIABLE,&#xD;&#xA;    PREPAYMENT_TAX_GROUP_CODE,&#xD;&#xA;    PREPMT_AMT_TO_DEDUCT,&#xD;&#xA;    PREPMT_AMT_DEDUCTED,&#xD;&#xA;    PREPAYMENT_LINE,&#xD;&#xA;    PREPMT_AMOUNT_INV_INCL_VAT,&#xD;&#xA;    IC_PARTNER_CODE,&#xD;&#xA;    DIMENSION_SET_ID,&#xD;&#xA;    VARIANT_CODE,&#xD;&#xA;    BIN_CODE,&#xD;&#xA;    QTY_PER_UNIT_OF_MEASURE,&#xD;&#xA;    PLANNED,&#xD;&#xA;    UNIT_OF_MEASURE_CODE,&#xD;&#xA;    QUANTITY_BASE,&#xD;&#xA;    OUTSTANDING_QTY_BASE,&#xD;&#xA;    QTY_TO_INVOICE_BASE,&#xD;&#xA;    QTY_TO_SHIP_BASE,&#xD;&#xA;    QTY_SHIPPED_NOT_INVD_BASE,&#xD;&#xA;    QTY_SHIPPED_BASE,&#xD;&#xA;    QTY_INVOICED_BASE,&#xD;&#xA;    FA_POSTING_DATE,&#xD;&#xA;    DEPRECIATION_BOOK_CODE,&#xD;&#xA;    DEPR_