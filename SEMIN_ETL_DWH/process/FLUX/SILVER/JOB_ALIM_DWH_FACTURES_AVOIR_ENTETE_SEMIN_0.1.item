    <elementParameter field="TACOKIT_VALUE_SELECTION" name="configuration.dataSet.tableName" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="&quot;&#xD;&#xA;insert into &quot;+context.Snowflake_BDD_Silver+&quot;.&quot;+context.Snowflake_Schema_Silver+&quot;.FACTURES_AVOIR_ENTETE_SEMIN&#xD;&#xA;(select distinct&#xD;&#xA;VE.\&quot;Document No_\&quot; as NO_, &#xD;&#xA;case when FE.SALESPERSON_CODE = ''       -- si aucun code vendeur n'est rattaché au sell_to_customer_no_&#xD;&#xA;     then case when FE.SHIP_TO_CODE = '' -- dans le cas où ship_to_code est vide&#xD;&#xA;          then FE.SELL_TO_CUSTOMER_NO_   -- on conserve SELL_TO_CUSTOMER_NO_&#xD;&#xA;          else FE.SHIP_TO_CODE end       --sinon on le remplace par SHIP_TO_CODE&#xD;&#xA;     else FE.SELL_TO_CUSTOMER_NO_ end as SELL_TO_CUSTOMER_NO_, &#xD;&#xA;VE.\&quot;Bill-to Customer No_\&quot; as BILL_TO_CUSTOMER_NO_,&#xD;&#xA;VE.\&quot;Posting Date\&quot; as POSTING_DATE,&#xD;&#xA;'' as LOCATION_CODE,&#xD;&#xA;FE.STAND as STAND,&#xD;&#xA;0 as CURRENCY_FACTOR,&#xD;&#xA;'SEMIN S_A_' as DATABASE_ORIGIN,&#xD;&#xA;'' as CLIENTSELL_KEY, &#xD;&#xA;'' as CLIENTBILL_KEY, &#xD;&#xA;'' as INVOICE_KEY, &#xD;&#xA;'' as CR_MEMO_KEY, &#xD;&#xA;'' as POSTING_DESCRIPTION, &#xD;&#xA;'' as ORDER_DATE, &#xD;&#xA;'' as ORDER_NO_&#xD;&#xA;from &quot;+context.Snowflake_BDD+&quot;.&quot;+context.Snowflake_Schema_SEMIN_SAS+&quot;.\&quot;Value_Entry\&quot; VE&#xD;&#xA;inner join &quot;+context.Snowflake_BDD+&quot;.&quot;+context.Snowflake_Schema_SEMIN_SAS+&quot;.\&quot;FACTURE_ENTETE_SEMIN_S_A_\&quot; FE&#xD;&#xA;on &#xD;&#xA;FE.NO_ = VE.\&quot;Document No_\&quot;&#xD;&#xA;where &#xD;&#xA;  VE.\&quot;Item Charge No_\&quot; = '' --frais annexes à écarter&#xD;&#xA;  and VE.\&quot;Item No_\&quot; not in ('A01400', 'A11067', 'A11068', 'A11069', 'A11070', 'A11599', 'A12254')&#xD;&#xA;  and VE.\&quot;Document Type\&quot; in ('2', '4')); -- factures vente et avoir vente);&#xD;&#xA;&quot;&#xD;&#xA;"/>
    <elementParameter field="CHECK" name="configuration.dieOnError" value="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.autoCommit" value="true" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.jdbcParameters" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.loginTimeout" value="15" show="false"/>
