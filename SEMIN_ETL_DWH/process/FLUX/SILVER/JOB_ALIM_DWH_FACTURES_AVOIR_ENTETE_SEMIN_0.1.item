    <elementParameter field="MEMO_SQL" name="configuration.sqlQuery" value="&quot;&#xD;&#xA;-- alimentation FACTURES_AVOIR_LIGNE_SEMIN&#xD;&#xA;insert into &quot;+context.Snowflake_BDD_Silver+&quot;.&quot;+context.Snowflake_Schema_Silver+&quot;.FACTURES_AVOIR_LIGNE_SEMIN&#xD;&#xA;(select &#xD;&#xA;VE.\&quot;Document No_\&quot; as DOCUMENT_NO_, &#xD;&#xA;VE.\&quot;Document Line No_\&quot; as LINE_NO_,&#xD;&#xA;VE.\&quot;Item No_\&quot; as NO_,&#xD;&#xA;VE.\&quot;Location Code\&quot; as LOCATION_CODE,&#xD;&#xA;I.\&quot;Description\&quot; as DESCRIPTION,&#xD;&#xA;FL.UNIT_OF_MEASURE as UNIT_OF_MEASURE, -- à récupérer idéalement dans Unit of Measure, mais elle n'existe pas&#xD;&#xA;FL.QUANTITY as QUANTITY,&#xD;&#xA;0 as UNIT_COST_LCY,&#xD;&#xA;VE.\&quot;Sales Amount (Actual)\&quot; as AMOUNT,&#xD;&#xA;VE.\&quot;Sales Amount (Actual)\&quot; as VAT_BASE_AMOUNT,&#xD;&#xA;VE.\&quot;Sales Amount (Actual)\&quot; as LINE_AMOUNT,&#xD;&#xA;FL.POIDS_NET_ART__ACHETE as POIDS_NET_ART__ACHETE,&#xD;&#xA;FL.POIDS_NET_ART__FABRIQUE as POIDS_NET_ART__FABRIQUE,&#xD;&#xA;VE.\&quot;Salespers__Purch_ Code\&quot; as CODE_VENDEUR, &#xD;&#xA;VE.\&quot;Coût semin (dev soc)\&quot; as COUT_SEMIN_DEV_SOC, &#xD;&#xA;VE.\&quot;Cout transport (dev soc)\&quot;*-1 as COUT_TRANSPORT__DEV_SOC, &#xD;&#xA;FL.POIDS_NET_ART__PROFILES as POIDS_NET_ART__PROFILES, &#xD;&#xA;I.\&quot;Sales Unit of Measure\&quot; as UNIT_OF_MEASURE_CODE, &#xD;&#xA;'SEMIN S_A_' as DATABASE_ORIGIN,&#xD;&#xA;'' as ARTICLE_KEY, &#xD;&#xA;'' as CR_MEMO_KEY, &#xD;&#xA;'' as INVOICE_KEY, &#xD;&#xA;'' as MAGASIN_KEY, &#xD;&#xA;'' as VENDEUR_KEY, &#xD;&#xA;VE.\&quot;Document Type\&quot; as TYPE, &#xD;&#xA;VE.\&quot;Invoiced Quantity\&quot;*-1 as QUANTITY_BASE&#xD;&#xA;from &quot;+context.Snowflake_BDD+&quot;.&quot;+context.Snowflake_Schema_SEMIN_SAS+&quot;.\&quot;Value_Entry\&quot; VE&#xD;&#xA;left outer join&#xD;&#xA;&quot;+context.Snowflake_BDD+&quot;.&quot;+context.Snowflake_Schema_SEMIN_SAS+&quot;.\&quot;Item\&quot; I&#xD;&#xA;on VE.\&quot;Item No_\&quot; = I.\&quot;No_\&quot;&#xD;&#xA;inner join&#xD;&#xA;&quot;+context.Snowflake_BDD+&quot;.&quot;+context.Snowflake_Schema_SEMIN_SAS+&quot;.FACTURE_LIGNE_SEMIN_S_A_ FL&#xD;&#xA;on &#xD;&#xA;FL.DOCUMENT_NO_ = VE.\&quot;Document No_\&quot;&#xD;&#xA;and FL.LINE_NO_ = VE.\&quot;Document Line No_\&quot;&#xD;&#xA;where &#xD;&#xA;  VE.\&quot;Item Charge No_\&quot; = '' --frais annexes à écarter&#xD;&#xA;  and VE.\&quot;Item No_\&quot; not in ('A01400', 'A11067', 'A11068', 'A11069', 'A11070', 'A11599', 'A12254')&#xD;&#xA;  and VE.\&quot;Document Type\&quot; in ('2', '4')) -- factures vente et avoir vente -- factures vente et avoir vente&#xD;&#xA;&#xD;&#xA;&quot;"/>
    <elementParameter field="CHECK" name="configuration.dieOnError" value="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.autoCommit" value="true" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.jdbcParameters" value="&quot;&quot;" show="false"/>
