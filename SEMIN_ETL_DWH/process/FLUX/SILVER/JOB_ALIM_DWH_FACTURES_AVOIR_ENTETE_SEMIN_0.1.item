    <elementParameter field="PASSWORD" name="configuration.dataSet.dataStore.snowflakeAuth.oauthPassword" value="enc:system.encryption.key.v1:Znvb6WAkSFcdIGtBuXAfuiBXNpHlREnm5EKJlCVe" show="false"/>
